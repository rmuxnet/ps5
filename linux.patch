diff --git a/drivers/devfreq/ps5-gpufreq.c b/drivers/devfreq/ps5-gpufreq.c
new file mode 100644
index 000000000000..43434a8a8615
--- /dev/null
+++ b/drivers/devfreq/ps5-gpufreq.c
@@ -0,0 +1,244 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#include <linux/cleanup.h>
+#include <linux/devfreq.h>
+#include <linux/init.h>
+#include <linux/module.h>
+#include <linux/mutex.h>
+#include <linux/platform_device.h>
+#include <linux/pm_opp.h>
+#include <linux/ps5.h>
+
+#include <asm/amd/node.h>
+
+#define PS5_SMU_NODE			0
+#define PS5_SMU_TIMEOUT			200000
+
+#define PS5_SMU_MSG			0x03b10a08
+#define PS5_SMU_RESP			0x03b10a68
+#define PS5_SMU_ARG			0x03b10a48
+
+#define PS5_SMU_MSG_REQUEST_GFXCLK	0x0e
+#define PS5_SMU_MSG_QUERY_GFXCLK	0x0f
+
+#define PS5_SMU_RESP_OK			1
+
+#define PS5_GFXCLK_MIN_MHZ		400UL
+#define PS5_GFXCLK_MAX_MHZ		2230UL
+#define PS5_GFXCLK_DEFAULT_MHZ		2000UL
+
+// TODO: manual pins here get overridden while ps5-cpufreq's boost is active
+// (SMU takes over GPU clock, snaps back to ceiling). idk what to do lol
+
+static int ps5_gpu_smu_wait(u32 reg, u32 *val)
+{
+	u32 tmp;
+	int i, ret;
+
+	for (i = 0; i < PS5_SMU_TIMEOUT; i++) {
+		ret = amd_smn_read(PS5_SMU_NODE, reg, &tmp);
+		if (ret)
+			return ret;
+		if (tmp) {
+			if (val)
+				*val = tmp;
+			return 0;
+		}
+		cpu_relax();
+	}
+
+	return -ETIMEDOUT;
+}
+
+static int ps5_gpu_smu_send(u8 msg, u32 arg, u32 *resp)
+{
+	u32 status, val;
+	int ret;
+
+	guard(mutex)(&ps5_mp1_q0_lock);
+
+	ret = ps5_gpu_smu_wait(PS5_SMU_RESP, NULL);
+	if (ret)
+		return ret;
+
+	ret = amd_smn_write(PS5_SMU_NODE, PS5_SMU_RESP, 0) ?:
+	      amd_smn_write(PS5_SMU_NODE, PS5_SMU_ARG, arg) ?:
+	      amd_smn_write(PS5_SMU_NODE, PS5_SMU_ARG + 4, 0) ?:
+	      amd_smn_write(PS5_SMU_NODE, PS5_SMU_MSG, msg);
+	if (ret)
+		return ret;
+
+	ret = ps5_gpu_smu_wait(PS5_SMU_RESP, &status);
+	if (ret)
+		return ret;
+
+	ret = amd_smn_read(PS5_SMU_NODE, PS5_SMU_ARG, &val);
+	if (ret)
+		return ret;
+
+	if ((status & 0xff) != PS5_SMU_RESP_OK)
+		return -EIO;
+
+	if (resp)
+		*resp = val;
+
+	return 0;
+}
+
+static int ps5_gpu_query_mhz(u32 *mhz)
+{
+	return ps5_gpu_smu_send(PS5_SMU_MSG_QUERY_GFXCLK, 0, mhz);
+}
+
+static int ps5_gpu_request_mhz(u32 mhz)
+{
+	int ret = ps5_gpu_smu_send(PS5_SMU_MSG_REQUEST_GFXCLK, mhz, NULL);
+
+	if (!ret)
+		pr_info("gpu freq set: %u MHz\n", mhz);
+
+	return ret;
+}
+
+static int ps5_gpufreq_target(struct device *dev, unsigned long *freq, u32 flags)
+{
+	unsigned long mhz = *freq / 1000000UL;
+
+	if (mhz < PS5_GFXCLK_MIN_MHZ)
+		mhz = PS5_GFXCLK_MIN_MHZ;
+	if (mhz > PS5_GFXCLK_MAX_MHZ)
+		mhz = PS5_GFXCLK_MAX_MHZ;
+
+	if (ps5_gpu_request_mhz(mhz))
+		return -EIO;
+
+	*freq = mhz * 1000000UL;
+
+	return 0;
+}
+
+static int ps5_gpufreq_get_cur_freq(struct device *dev, unsigned long *freq)
+{
+	u32 mhz;
+
+	if (ps5_gpu_query_mhz(&mhz))
+		return -EIO;
+
+	*freq = (unsigned long)mhz * 1000000UL;
+
+	return 0;
+}
+
+static int ps5_gpufreq_get_dev_status(struct device *dev,
+				       struct devfreq_dev_status *stat)
+{
+	unsigned long freq;
+	int ret;
+
+	ret = ps5_gpufreq_get_cur_freq(dev, &freq);
+	if (ret)
+		return ret;
+
+	stat->current_frequency = freq;
+	stat->total_time = 1;
+	stat->busy_time = 1;
+
+	return 0;
+}
+
+static unsigned long ps5_gpufreq_table[] = {
+	PS5_GFXCLK_MIN_MHZ * 1000000UL,
+	PS5_GFXCLK_MAX_MHZ * 1000000UL,
+};
+
+static struct devfreq_dev_profile ps5_gpufreq_profile = {
+	.initial_freq	= PS5_GFXCLK_DEFAULT_MHZ * 1000000UL,
+	.polling_ms	= 0,
+	.target		= ps5_gpufreq_target,
+	.get_cur_freq	= ps5_gpufreq_get_cur_freq,
+	.get_dev_status	= ps5_gpufreq_get_dev_status,
+	.freq_table	= ps5_gpufreq_table,
+	.max_state	= ARRAY_SIZE(ps5_gpufreq_table),
+};
+
+static int ps5_gpufreq_probe(struct platform_device *pdev)
+{
+	struct devfreq *df;
+	int ret, i;
+
+	for (i = 0; i < ARRAY_SIZE(ps5_gpufreq_table); i++) {
+		struct dev_pm_opp_data data = { .freq = ps5_gpufreq_table[i] };
+
+		ret = dev_pm_opp_add_dynamic(&pdev->dev, &data);
+		if (ret)
+			goto err_remove_opp;
+	}
+
+	df = devm_devfreq_add_device(&pdev->dev, &ps5_gpufreq_profile,
+				      DEVFREQ_GOV_USERSPACE, NULL);
+	if (IS_ERR(df)) {
+		ret = PTR_ERR(df);
+		goto err_remove_opp;
+	}
+
+	platform_set_drvdata(pdev, df);
+
+	ps5_gpu_request_mhz(PS5_GFXCLK_MAX_MHZ);
+
+	return 0;
+
+err_remove_opp:
+	for (i--; i >= 0; i--)
+		dev_pm_opp_remove(&pdev->dev, ps5_gpufreq_table[i]);
+
+	return ret;
+}
+
+static void ps5_gpufreq_remove(struct platform_device *pdev)
+{
+	int i;
+
+	for (i = 0; i < ARRAY_SIZE(ps5_gpufreq_table); i++)
+		dev_pm_opp_remove(&pdev->dev, ps5_gpufreq_table[i]);
+}
+
+static struct platform_driver ps5_gpufreq_driver = {
+	.driver = {
+		.name = "ps5-gpufreq",
+	},
+	.probe = ps5_gpufreq_probe,
+	.remove = ps5_gpufreq_remove,
+};
+
+static struct platform_device *ps5_gpufreq_pdev;
+
+static int __init ps5_gpufreq_init(void)
+{
+	int ret;
+
+	pr_info("Strawberry was here\n");
+
+	ret = platform_driver_register(&ps5_gpufreq_driver);
+	if (ret)
+		return ret;
+
+	ps5_gpufreq_pdev = platform_device_register_simple("ps5-gpufreq", -1, NULL, 0);
+	if (IS_ERR(ps5_gpufreq_pdev)) {
+		platform_driver_unregister(&ps5_gpufreq_driver);
+		return PTR_ERR(ps5_gpufreq_pdev);
+	}
+
+	return 0;
+}
+module_init(ps5_gpufreq_init);
+
+static void __exit ps5_gpufreq_exit(void)
+{
+	platform_device_unregister(ps5_gpufreq_pdev);
+	platform_driver_unregister(&ps5_gpufreq_driver);
+}
+module_exit(ps5_gpufreq_exit);
+
+MODULE_DESCRIPTION("PlayStation 5 SMU GFXCLK devfreq driver");
+MODULE_AUTHOR("Armandas Kvietkus <armandas.kvietkus@proton.me>");
+MODULE_LICENSE("GPL");
