+			 BTUSB_IFNUM_0 |
+			 BTUSB_BROKEN_LE_DEFAULT_PHY |
+			 BTUSB_BROKEN_READ_LOCAL_NAME |
+			 BTUSB_NO_AUTOSUSPEND },
+
 	{ }	/* Terminating entry */
 };
 
@@ -472,6 +484,11 @@ static const struct usb_device_id quirks_table[] = {
