diff --git a/drivers/cpufreq/ps5-cpufreq.c b/drivers/cpufreq/ps5-cpufreq.c
new file mode 100644
index 000000000000..95b2c095b53c
--- /dev/null
+++ b/drivers/cpufreq/ps5-cpufreq.c
@@ -0,0 +1,159 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#include <linux/bitfield.h>
+#include <linux/cpufreq.h>
+#include <linux/init.h>
+#include <linux/module.h>
+#include <linux/mutex.h>
+#include <linux/ps5.h>
+
+#include <asm/amd/node.h>
+
+#define PS5_SMU_NODE			0
+#define PS5_SMU_TIMEOUT			200000
+
+#define PS5_SMU_MSG			0x03b10a08
+#define PS5_SMU_RESP			0x03b10a68
+#define PS5_SMU_ARG			0x03b10a48
+
+#define PS5_SMU_MSG_SET_PSTATE		0x0b
+
+#define PS5_PSTATE_MASK			GENMASK(19, 16)
+#define PS5_CORE_MASK_ALL		0xff
+
+#define PS5_SMU_RESP_OK			1
+
+#define PS5_CPU_MHZ_FLOOR		3200
+#define PS5_CPU_MHZ_CEIL		3500
+
+#define PS5_GPU_MHZ_FLOOR		2000
+#define PS5_GPU_MHZ_CEIL		2230
+
+#define PS5_TRANSITION_LATENCY_NS	50000
+
+static int ps5_smu_wait(u32 reg, u32 *val)
+{
+	u32 tmp;
+	int i, ret;
+
+	for (i = 0; i < PS5_SMU_TIMEOUT; i++) {
+		ret = amd_smn_read(PS5_SMU_NODE, reg, &tmp);
+		if (ret)
+			return ret;
+		if (tmp) {
+			if (val)
+				*val = tmp;
+			return 0;
+		}
+		cpu_relax();
+	}
+
+	return -ETIMEDOUT;
+}
+
+static int ps5_smu_send(u8 msg, u32 arg, u32 *resp)
+{
+	u32 status, val;
+	int ret;
+
+	mutex_lock(&ps5_mp1_q0_lock);
+
+	ret = ps5_smu_wait(PS5_SMU_RESP, NULL);
+	if (ret)
+		goto out_unlock;
+
+	ret = amd_smn_write(PS5_SMU_NODE, PS5_SMU_RESP, 0) ?:
+	      amd_smn_write(PS5_SMU_NODE, PS5_SMU_ARG, arg) ?:
+	      amd_smn_write(PS5_SMU_NODE, PS5_SMU_ARG + 4, 0) ?:
+	      amd_smn_write(PS5_SMU_NODE, PS5_SMU_MSG, msg);
+	if (ret)
+		goto out_unlock;
+
+	ret = ps5_smu_wait(PS5_SMU_RESP, &status);
+	if (ret)
+		goto out_unlock;
+
+	ret = amd_smn_read(PS5_SMU_NODE, PS5_SMU_ARG, &val);
+	if (ret)
+		goto out_unlock;
+
+	if ((status & 0xff) != PS5_SMU_RESP_OK) {
+		ret = -EIO;
+		goto out_unlock;
+	}
+
+	if (resp)
+		*resp = val;
+
+out_unlock:
+	mutex_unlock(&ps5_mp1_q0_lock);
+	return ret;
+}
+
+static struct cpufreq_frequency_table ps5_freq_table[] = {
+	{ .flags = CPUFREQ_BOOST_FREQ, .driver_data = 0xff, .frequency = 3500000 },
+	{ .flags = CPUFREQ_BOOST_FREQ, .driver_data = 0xff, .frequency = 3400000 },
+	{ .flags = CPUFREQ_BOOST_FREQ, .driver_data = 0xff, .frequency = 3300000 },
+	{ .driver_data = 0, .frequency = 3200000 },
+	{ .driver_data = 1, .frequency = 2560000 },
+	{ .driver_data = 2, .frequency = 2327000 },
+	{ .driver_data = 3, .frequency = 1969000 },
+	{ .driver_data = 4, .frequency = 1829000 },
+	{ .driver_data = 5, .frequency = 1600000 },
+	{ .driver_data = 6, .frequency = 1280000 },
+	{ .driver_data = 7, .frequency =  800000 },
+	{ .frequency = CPUFREQ_TABLE_END },
+};
+
+static int ps5_cpufreq_target_index(struct cpufreq_policy *policy,
+				    unsigned int index)
+{
+	u32 pstate = ps5_freq_table[index].driver_data;
+	u32 arg;
+
+	pr_info("cpu freq set: %u MHz\n", ps5_freq_table[index].frequency / 1000);
+
+	if (pstate == 0xff)
+		return mp1_boost_enter(PS5_CPU_MHZ_FLOOR, PS5_CPU_MHZ_CEIL,
+					PS5_GPU_MHZ_FLOOR, PS5_GPU_MHZ_CEIL);
+
+	arg = PS5_CORE_MASK_ALL | FIELD_PREP(PS5_PSTATE_MASK, pstate);
+	return ps5_smu_send(PS5_SMU_MSG_SET_PSTATE, arg, NULL);
+}
+
+static int ps5_cpufreq_cpu_init(struct cpufreq_policy *policy)
+{
+	cpumask_copy(policy->cpus, cpu_present_mask);
+	policy->freq_table = ps5_freq_table;
+	policy->cpuinfo.transition_latency = PS5_TRANSITION_LATENCY_NS;
+	policy->boost_supported = true;
+
+	return 0;
+}
+
+static struct cpufreq_driver ps5_cpufreq_driver = {
+	.name		= "ps5-cpufreq",
+	.flags		= CPUFREQ_CONST_LOOPS,
+	.verify		= cpufreq_generic_frequency_table_verify,
+	.target_index	= ps5_cpufreq_target_index,
+	.init		= ps5_cpufreq_cpu_init,
+	.set_boost	= cpufreq_boost_set_sw,
+	.boost_enabled	= false,
+};
+
+static int __init ps5_cpufreq_init(void)
+{
+	pr_info("Strawberry was here\n");
+	return cpufreq_register_driver(&ps5_cpufreq_driver);
+}
+module_init(ps5_cpufreq_init);
+
+static void __exit ps5_cpufreq_exit(void)
+{
+	cpufreq_unregister_driver(&ps5_cpufreq_driver);
+}
+module_exit(ps5_cpufreq_exit);
+
+MODULE_DESCRIPTION("PlayStation 5 SMU cpufreq driver");
+MODULE_AUTHOR("Armandas Kvietkus <armandas.kvietkus@proton.me>");
+MODULE_LICENSE("GPL");
